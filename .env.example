# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: OpenAI API key for the agent and eval judge
OPENAI_API_KEY=sk-...

# LLM models (defaults are fine for most use cases)
# MODEL=gpt-5.4           # Primary reasoning model
# SWEEP_MODEL=gpt-4.1     # Cheaper model for V4 sweep call
# JUDGE_MODEL=gpt-5.4     # Eval judge model

# Observability backend URLs (defaults point to local Docker)
# Change these to point at a remote GCP deployment if needed
# LOKI_URL=http://localhost:3100
# MIMIR_URL=http://localhost:9090
# TEMPO_URL=http://localhost:3200
